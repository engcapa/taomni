{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Taomni",
  "version": "../package.json",
  "identifier": "com.taomni.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1980",
    "beforeDevCommand": "bash scripts/bundle-krb5-macos.sh stage && pnpm dev",
    "beforeBuildCommand": "pnpm build && bash scripts/bundle-krb5-macos.sh stage",
    "beforeBundleCommand": "bash scripts/bundle-krb5-macos.sh fixbin"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "create": false,
        "title": "Taomni",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/ai-generations/**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "frameworks": [
        "frameworks/libgssapi_krb5.2.2.dylib",
        "frameworks/libkrb5.3.3.dylib",
        "frameworks/libk5crypto.3.1.dylib",
        "frameworks/libcom_err.3.0.dylib",
        "frameworks/libkrb5support.1.1.dylib"
      ]
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/engcapa/taomni/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRFNjk5MkMyRTUyQUU4OTUKUldTVjZDcmx3cEpwVHJpSWJyMGdyQXA0b2p0T3hQSEZNRFFZYjg5KzhEQXVPK0ViT0FOZjA4N1AK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
